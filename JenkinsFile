pipeline {
    agent any

    tools {
        nodejs 'Node20'
    }

    stages {

        stage('Install Dependencies') {
            steps {
                sh 'npm install'
            }
        }

        stage('Build Angular') {
            steps {
                sh 'npm run build'
            }
        }

        stage('Check Build Output') {
            steps {
                sh 'ls -R dist'
            }
        }

        stage('Docker Build') {
            steps {
                sh 'docker build -t angular-app:${BUILD_NUMBER} .'
            }
        }
    }
}